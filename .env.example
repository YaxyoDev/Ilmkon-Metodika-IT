# Namuna sozlamalar. Serverda (cPanel) shu faylni `.env` deb nusxalab,
# qiymatlarni to'ldiring. `.env` git'ga kirmaydi (xavfsizlik uchun).
# Agar `.env` bo'lmasa, ilova quyidagi standart qiymatlar bilan ishlayveradi.

# --- Ma'lumotlar bazasi ---
# Standart: loyiha ildizidagi SQLite fayl (mutlaq yo'l avtomatik hisoblanadi).
# Qoldirsangiz ham ishlaydi — cPanel'da qo'shimcha DB server shart emas.
# DATABASE_URL=sqlite+aiosqlite:///./metodika.db
# PostgreSQL misoli:
# DATABASE_URL=postgresql+asyncpg://user:parol@localhost:5432/metodikait

# --- Muhit ---
# Production serverda ENV=prod qo'ying. Shunda JWT_SECRET o'rnatilmagan bo'lsa
# ilova ishga tushmaydi (xavfsizlik uchun, 7.1-band).
# ENV=prod

# --- JWT ---
# PRODUCTION uchun JWT_SECRET ni ALBATTA o'zingizning tasodifiy qiymatingizga
# almashtiring (masalan: `openssl rand -hex 48`). Aks holda standart kalit
# ishlatiladi va tokenlar xavfsiz bo'lmaydi.
JWT_SECRET=U3TfQ4UHBLeKgk-p7B-huDYde6_gmd0V3QqSInobYxr4agZ8w7pkElsQ7ltdjIqu
JWT_ALGORITHM=HS256
TOKEN_TTL_HOURS=24

